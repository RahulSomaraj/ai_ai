// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// FOUNDATION ENTITIES (Academic Structure)
// ============================================

model Subject {
  id        String     @id @default(uuid())
  name      String     // e.g., "Physics"
  class     Int        // e.g., 11
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  textbooks Textbook[]

  // Indexes for common queries
  @@index([name, class])
  @@map("subjects")
}

model Textbook {
  id         String   @id @default(uuid())
  subjectId String
  title      String   // e.g., "Physics Part 1"
  code       String?  // e.g., "PH11-P1" (optional identifier)
  order      Int      // Order within subject (1, 2, 3...)
  source     String   @default("NCERT") // e.g., "NCERT", "State Board"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([subjectId, order])
  @@unique([subjectId, order])
  @@map("textbooks")
}

model RagDocument {
  id         String   @id @default(uuid())
  title      String
  subject    String
  classLevel Int      @map("class_level")
  chapter    String
  exercise   String?
  sourceType String   @default("ncert_book") @map("source_type")
  sourcePath String?  @map("source_path")
  createdAt  DateTime @default(now()) @map("created_at")

  chunks RagChunk[]

  @@index([subject, classLevel, chapter])
  @@map("documents")
}

model RagChunk {
  id         String   @id @default(uuid())
  documentId String   @map("document_id")
  chunkIndex Int      @map("chunk_index")
  content    String
  tokenCount Int      @map("token_count")
  pageNo     Int?     @map("page_no")
  section    String?
  createdAt  DateTime @default(now()) @map("created_at")

  document  RagDocument       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  embedding RagChunkEmbedding?

  @@index([documentId, chunkIndex])
  @@map("chunks")
}

model RagChunkEmbedding {
  chunkId   String                  @id @map("chunk_id")
  embedding Unsupported("vector(1536)")
  model     String
  createdAt DateTime                @default(now()) @map("created_at")

  chunk RagChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@map("chunk_embeddings")
}

